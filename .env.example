# Copy to .env and fill in. Never commit .env.
# All keys are optional locally — the app starts without them, but generation
# requires at least one backend credential.

# --- Compute backends ---
REPLICATE_API_TOKEN=
FAL_KEY=

# Required only for the Training Studio: a Replicate model you own where trained
# LoRAs will be pushed (create it at https://replicate.com/create first).
# Format: "username/model-name"
REPLICATE_DESTINATION=

# --- App behaviour ---
# Which backend to use when multiple can serve a strategy. "replicate" | "fal"
IMGGEN_DEFAULT_BACKEND=replicate

# Per-IP daily spend cap in USD. Set to 0 to disable (not recommended for public deploys).
IMGGEN_DAILY_SPEND_CAP_USD=5.00

# Paths (override if you want data elsewhere)
IMGGEN_DATA_DIR=data
IMGGEN_DB_PATH=data/runs/runs.duckdb

# Logging: "console" for human-readable dev output, "json" for production
IMGGEN_LOG_FORMAT=console
IMGGEN_LOG_LEVEL=INFO
